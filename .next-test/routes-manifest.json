      "page": "/products/[id]",
      "regex": "^/products/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/products/(?<nxtPid>[^/]+?)(?:/)?$"
    }
  ],
